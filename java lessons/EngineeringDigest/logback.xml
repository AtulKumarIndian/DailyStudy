Logging levels = TRACE DEBUG INFO WARN ERROR
this file needs to be created for logging into files or console
Basically uses appenders - encoders and pattern
you can use log variable from @Slf4j
 -5level = left justified min 5 width levels 

<configuration>
    <appender name = "myConsoleAppender" class="ch.qos.logback.core.ConsoleAppender">
      <file>
        appname.log
      </file>      
      <encoder>
        <pattern>
            %d{yy-MM-dd HH:mmm:ss.SSS} [%thread] %-5level %logger{36} - %msg %n
        </pattern>
      </encoder>
    </appender>
    <appender  name = "myFileAppender" class="ch.qos.logback.core.FileAppender">
      <encoder>
        <pattern>
            %d{yy-MM-dd HH:mmm:ss.SSS} [%thread] %-5level %logger{36} - %msg %n
        </pattern>
      </encoder>  
    </appender>

    <appender  name = "myFileAppender" class="ch.qos.logback.core.RollingFileAppender">
      <file>
        appname.log
      </file>   
      <rollingPolicy class = "ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
        <fileNamePattern>appname-%d{yy-MM-dd_HH}.%i.log
        <maxFileSize>10MB</maxFileSize>
        <maxHistory>10</maxHistory>
      </rollingPolicy>
      <encoder>
        <pattern>
            %d{yy-MM-dd HH:mmm:ss.SSS} [%thread] %-5level %logger{36} - %msg %n
        </pattern>
      </encoder> 
    </appender>

    <root level="INFO">
        <appender-ref ref = "myConsoleAppender" />
        <appender-ref ref = "myFileAppender" />
    </root>
</configuration>